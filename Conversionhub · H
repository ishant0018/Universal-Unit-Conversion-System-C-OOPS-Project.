#pragma once
#include <string>

class Converter;
class ConversionResult;

using std::string;
using std::cout;
using std::invalid_argument;

// Manages all 10 converters.
class ConversionHub {
    static const int COUNT = 10;
    Converter* converters[COUNT];
    string     keys[COUNT];

    int findIndex(const string& cat) const {
        for (int i = 0; i < COUNT; i++)
            if (keys[i] == cat) return i;
        return -1;
    }

    string toLower(const string& s) const {
        string r = s;
        for (int i = 0; i < (int)r.size(); i++)
            if (r[i] >= 'A' && r[i] <= 'Z')
                r[i] = r[i] + 32;
        return r;
    }

public:
    ConversionHub();
    ~ConversionHub();
    ConversionResult convert(const string& category,
                              double value,
                              const string& from,
                              const string& to) const;

    void listAllUnits()   const;
    void listCategories() const;
};